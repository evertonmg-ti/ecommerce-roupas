generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
}

enum ShippingMethod {
  STANDARD
  EXPRESS
  PICKUP
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  price       Decimal       @db.Decimal(10, 2)
  compareAt   Decimal?      @db.Decimal(10, 2)
  stock       Int
  status      ProductStatus @default(DRAFT)
  imageUrl    String?
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Order {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  subtotal           Decimal        @default(0) @db.Decimal(10, 2)
  shippingCost       Decimal        @default(0) @db.Decimal(10, 2)
  total              Decimal        @db.Decimal(10, 2)
  status             OrderStatus    @default(PENDING)
  paymentMethod      PaymentMethod  @default(PIX)
  shippingMethod     ShippingMethod @default(STANDARD)
  shippingAddress    String         @default("Nao informado")
  shippingAddress2   String?
  shippingCity       String         @default("Nao informado")
  shippingState      String         @default("NI")
  shippingPostalCode String         @default("00000000")
  notes              String?
  items              OrderItem[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}
