generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryMovementType {
  INITIAL
  MANUAL_ADJUSTMENT
  ORDER_RESERVATION
  ORDER_CANCELLATION
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
}

enum ShippingMethod {
  STANDARD
  EXPRESS
  PICKUP
}

enum ReturnRequestType {
  EXCHANGE
  REFUND
}

enum ReturnRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  COMPLETED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum EventLevel {
  INFO
  WARN
  ERROR
  SECURITY
}

model AppSettings {
  id            Int      @id @default(1)
  storeName     String   @default("Maison Aurea")
  storeUrl      String   @default("http://localhost:3000")
  supportEmail  String?
  monthlyRevenueTarget Decimal @default(0) @db.Decimal(12, 2)
  minimumMarginTarget Float   @default(25)
  emailEnabled  Boolean  @default(false)
  emailFrom     String   @default("Maison Aurea <no-reply@maisonaurea.local>")
  emailReplyTo  String?
  emailOrdersTo String?
  smtpHost      String?
  smtpPort      Int      @default(587)
  smtpSecure    Boolean  @default(false)
  smtpUser      String?
  smtpPass      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorName   String?
  actorRole   String?
  method      String
  path        String
  action      String
  entityType  String?
  entityId    String?
  statusCode  Int?
  ipAddress   String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorEmail, createdAt])
  @@index([path, createdAt])
}

model SystemEvent {
  id        String     @id @default(cuid())
  type      String
  level     EventLevel @default(INFO)
  source    String
  message   String
  metadata  Json?
  createdAt DateTime   @default(now())

  @@index([createdAt])
  @@index([level, createdAt])
  @@index([type, createdAt])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  preferredPaymentMethod PaymentMethod?
  preferredShippingMethod ShippingMethod?
  orders       Order[]
  returnRequests ReturnRequest[]
  addresses    CustomerAddress[]
  savedCart    SavedCart?
  savedWishlist SavedWishlist?
  inventoryMovements InventoryMovement[]
  passwordResetTokens PasswordResetToken[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SavedCart {
  id        String          @id @default(cuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     SavedCartItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SavedCartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  cart      SavedCart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  createdAt DateTime        @default(now())

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model SavedWishlist {
  id        String              @id @default(cuid())
  userId    String              @unique
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     SavedWishlistItem[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model SavedWishlistItem {
  id        String        @id @default(cuid())
  wishlistId String
  productId  String
  wishlist   SavedWishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product      @relation(fields: [productId], references: [id])
  createdAt  DateTime     @default(now())

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
}

model CustomerAddress {
  id                   String   @id @default(cuid())
  userId               String
  label                String
  recipientName        String
  customerDocument     String?
  customerPhone        String?
  shippingAddress      String
  shippingNumber       String
  shippingAddress2     String?
  shippingNeighborhood String
  shippingCity         String
  shippingState        String
  shippingPostalCode   String
  isDefault            Boolean  @default(false)
  favoriteForStandard  Boolean  @default(false)
  favoriteForExpress   Boolean  @default(false)
  favoriteForPickup    Boolean  @default(false)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId, isDefault])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  description String?
  type        CouponType
  value       Decimal    @db.Decimal(10, 2)
  active      Boolean    @default(true)
  minSubtotal Decimal    @default(0) @db.Decimal(10, 2)
  usageLimit  Int?
  usedCount   Int        @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  orders      Order[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  price       Decimal       @db.Decimal(10, 2)
  costPrice   Decimal       @default(0) @db.Decimal(10, 2)
  compareAt   Decimal?      @db.Decimal(10, 2)
  stock       Int
  status      ProductStatus @default(DRAFT)
  imageUrl    String?
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  orderItems  OrderItem[]
  savedCartItems SavedCartItem[]
  savedWishlistItems SavedWishlistItem[]
  inventoryMovements InventoryMovement[]
  backInStockSubscriptions BackInStockSubscription[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductVariant {
  id            String    @id @default(cuid())
  productId     String
  sku           String    @unique
  color         String?
  size          String?
  optionLabel   String
  priceOverride Decimal?  @db.Decimal(10, 2)
  compareAtOverride Decimal? @db.Decimal(10, 2)
  stock         Int
  imageUrl      String?
  isDefault     Boolean   @default(false)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  savedCartItems SavedCartItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productId, isDefault])
  @@index([productId, color])
  @@index([productId, size])
}

model Order {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  couponId           String?
  coupon             Coupon?        @relation(fields: [couponId], references: [id])
  couponCode         String?
  discountAmount     Decimal        @default(0) @db.Decimal(10, 2)
  subtotal           Decimal        @default(0) @db.Decimal(10, 2)
  shippingCost       Decimal        @default(0) @db.Decimal(10, 2)
  total              Decimal        @db.Decimal(10, 2)
  status             OrderStatus    @default(PENDING)
  paymentMethod      PaymentMethod  @default(PIX)
  shippingMethod     ShippingMethod @default(STANDARD)
  recipientName      String?
  customerDocument   String?
  customerPhone      String?
  shippingAddress    String         @default("Nao informado")
  shippingNumber     String?
  shippingAddress2   String?
  shippingNeighborhood String?
  shippingCity       String         @default("Nao informado")
  shippingState      String         @default("NI")
  shippingPostalCode String         @default("00000000")
  trackingCode       String?
  paidAt             DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  canceledAt         DateTime?
  notes              String?
  items              OrderItem[]
  returnRequests     ReturnRequest[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model ReturnRequest {
  id             String              @id @default(cuid())
  orderId        String
  userId         String
  type           ReturnRequestType
  status         ReturnRequestStatus @default(REQUESTED)
  reason         String
  details        String?
  selectedItems  Json?
  resolutionNote String?
  order          Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([orderId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  productId     String
  orderId       String?
  actorUserId   String?
  type          InventoryMovementType
  quantityDelta Int
  previousStock Int
  nextStock     Int
  reason        String?
  product       Product               @relation(fields: [productId], references: [id])
  order         Order?                @relation(fields: [orderId], references: [id])
  actorUser     User?                 @relation(fields: [actorUserId], references: [id])
  createdAt     DateTime              @default(now())

  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@index([orderId])
  @@index([actorUserId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  variantSku String?
  variantLabel String?
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model AbandonedCart {
  id            String              @id @default(cuid())
  email         String
  customerName  String?
  token         String              @unique
  lastEmailSentAt DateTime?
  recoveredAt   DateTime?
  items         AbandonedCartItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([email, updatedAt])
  @@index([token])
}

model AbandonedCartItem {
  id           String        @id @default(cuid())
  cartId       String
  productId    String
  variantId    String?
  variantSku   String?
  variantLabel String?
  productName  String
  productSlug  String
  imageUrl     String?
  categoryName String?
  quantity     Int
  unitPrice    Decimal       @db.Decimal(10, 2)
  cart         AbandonedCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@index([cartId])
  @@index([productId])
}

model BackInStockSubscription {
  id         String   @id @default(cuid())
  email      String
  productId  String
  active     Boolean  @default(true)
  notifiedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
  @@index([productId, active])
  @@index([email, active])
}
